{
  "expo": {
    "name": "UHAS BASIC SCHOOL",
    "slug": "uhas-basic-school",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/UBS.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/UBS.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.uhasbasicschool.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/UBS.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.uhasbasicschool.app",
      "edgeToEdgeEnabled": true
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font",
      "expo-secure-store"
    ],
    "extra": {}
  }
}
